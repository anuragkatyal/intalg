  </tabular>
<!-- </table> -->

<answer>
  <award>
    <when>
      $entry16=x and
      $entry24=$b x and
      $entry25=- and
      $entry26=$c and
      $entry33=$d x and
      $entry34=- and
      $entry35=$a and
      $entry42=$e x and
      $entry43=- and
      $entry44=$f and
      $entry51=$g x and
      $entry52=- and
      $entry53=$h and
      $entry62=$i
    </when>
  </award>
</answer>
  </div>
